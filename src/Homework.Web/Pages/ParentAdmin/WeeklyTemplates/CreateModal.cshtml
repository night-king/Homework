@page
@using Microsoft.AspNetCore.Mvc.Localization
@using Homework.Localization
@using Volo.Abp.AspNetCore.Mvc.UI.Bootstrap.TagHelpers.Modal
@model Homework.Web.Pages.ParentAdmin.WeeklyTemplates.CreateModalModel
@inject IHtmlLocalizer<HomeworkResource> L
<form asp-page="/ParentAdmin/WeeklyTemplates/CreateModal">
    <abp-modal>
        <abp-modal-header title="@L["Create"].Value"></abp-modal-header>
        <abp-modal-body>
            <abp-input asp-for="ChildId" />
            <div class="mb-3">
                <label asp-for="Input.DayOfWeek" class="form-label">@L["DayOfWeek"].Value</label>
                <select asp-for="Input.DayOfWeek" class="form-select">
                    <option value="0">@L["Day0"].Value</option>
                    <option value="1">@L["Day1"].Value</option>
                    <option value="2">@L["Day2"].Value</option>
                    <option value="3">@L["Day3"].Value</option>
                    <option value="4">@L["Day4"].Value</option>
                    <option value="5">@L["Day5"].Value</option>
                    <option value="6">@L["Day6"].Value</option>
                </select>
            </div>
            <abp-input asp-for="Input.Title" label="@L["Title"].Value" />
            <abp-input asp-for="Input.Subject" label="@L["Subject"].Value" />
            <abp-input asp-for="Input.Order" type="number" label="@L["Order"].Value" />
            <abp-input asp-for="Input.EstimatedMinutes" type="number" label="@L["EstimatedMinutes"].Value" />
        </abp-modal-body>
        <abp-modal-footer buttons="@(AbpModalButtons.Cancel | AbpModalButtons.Save)"></abp-modal-footer>
    </abp-modal>
</form>
