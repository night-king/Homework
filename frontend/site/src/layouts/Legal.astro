---
import Base from './Base.astro';

export interface Props {
  title: string;
  heading: string;
  path: string;
  description?: string;
  updated?: string;
}
const {
  title,
  heading,
  path,
  description = '学习小伙伴的法务条款。上线前将经儿童隐私合规专业审核。',
  updated = '2026-07-05（初稿框架，待法律审核）',
} = Astro.props;
---

<Base title={title} description={description} path={path}>
  <article class="legal">
    <div class="wrap narrow">
      <span class="eyebrow">法务</span>
      <h1>{heading}</h1>
      <div class="warn" role="note">
        <strong>⚠️ 初稿框架，尚未经法律审核。</strong>
        本页为"给人话版"占位内容，<strong>不构成法律意见</strong>。正式上线前将由懂儿童隐私合规
        （COPPA / 未成年人个人信息保护）的专业人士审定。
      </div>
      <p class="fineprint updated">最后更新：{updated}</p>
      <div class="prose"><slot /></div>
    </div>
  </article>
</Base>

<style is:global>
  .legal { padding-block: clamp(48px, 7vw, 96px); }
  .legal .narrow { margin-inline: auto; }
  .legal h1 { font-size: clamp(2.2rem, 5vw, 3.2rem); margin: .3em 0 .6em; }
  .legal .warn {
    background: var(--blush); border: 1px solid color-mix(in srgb, var(--coral) 30%, var(--line));
    border-radius: var(--radius); padding: 18px 22px; color: var(--ink); margin-bottom: 12px; line-height: 1.6;
  }
  .legal .updated { margin: 0 0 32px; }
  .legal .prose h2 { font-size: 1.5rem; margin-top: 1.6em; }
  .legal .prose p, .legal .prose li { color: var(--ink-soft); }
  .legal .prose ul { padding-left: 1.2em; }
  .legal .prose li { margin: .4em 0; }
</style>
